{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "framework": "create-react-app",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://unincarnate-kellie-complexionally.ngrok-free.dev/:path*"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "ngrok-skip-browser-warning", "value": "true" }
      ]
    }
  ]
}
